# --- PostgreSQL / Supabase -----------------------------------------------
PG_HOST=
PG_PORT=5432
PG_DB=postgres
PG_USER=postgres
PG_PASSWORD=

# --- Neo4j Aura ----------------------------------------------------------
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- MongoDB Atlas -------------------------------------------------------
